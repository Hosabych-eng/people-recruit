# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL="postgresql://recruit:recruit_dev@localhost:5432/people_recruit?schema=public"

# App — must match the port shown when you run `npm run dev`
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Session signing secret (change in production)
AUTH_SECRET="people-recruit-local-dev-secret"

# NextAuth (Google OAuth)
# IMPORTANT: NEXTAUTH_URL must use the SAME host:port as the running dev server.
# If Next.js falls back to port 3010, set NEXTAUTH_URL="http://localhost:3010" here.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_key"
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Bootstrap admin for seed (must match your Google account email)
SEED_ADMIN_EMAIL="admin@example.com"

# Interview emails and calendar invites are sent via the logged-in user's
# Google account (Gmail + Calendar APIs). Re-sign in after enabling OAuth scopes.
