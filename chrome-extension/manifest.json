{
  "manifest_version": 3,
  "name": "PeopleRecruit Importer",
  "version": "1.2.1",
  "description": "Import candidates from LinkedIn and Djinni into PeopleRecruit CRM",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.djinni.co/*",
    "https://people-recruit.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Import to PeopleRecruit"
  }
}
