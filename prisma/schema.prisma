// Prisma schema for PeopleRecruit ATS MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum WorkforceEventType {
  RECRUITING_IN
  RECRUITING_OUT
  ONBOARDING
  OFFBOARDING
}

enum UserRole {
  ADMIN
  RECRUITER
}

enum UserStatus {
  ACTIVE
  PENDING
}

enum ApplicationSource {
  DJINNI
  DOU
  LINKEDIN
  ROBOTA_UA
  SNOOPGAME
  MANUAL
  CAREER_SITE
  CAREERS
}

enum InterviewStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum InterviewType {
  ONLINE
  ONSITE
  PHONE
}

enum EmailMessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

enum EmailDirection {
  OUTBOUND
  INBOUND
}

enum CandidateDocumentCategory {
  RESUME
  PORTFOLIO
  OFFER
  OTHER
}

enum TestAssignmentDeliveryStatus {
  QUEUED
  SENT
  FAILED
  SUBMITTED
}

enum LanguageType {
  ENGLISH
  CHINESE
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole   @default(RECRUITER)
  status        UserStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts     Account[]
  sessions     Session[]
  assignedJobs Job[]       @relation("JobRecruiter")
  candidates   Candidate[] @relation("CandidateRecruiter")

  @@index([role])
  @@index([status])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Invitation {
  id        String   @id @default(uuid())
  email     String   @unique
  role      UserRole @default(RECRUITER)
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@map("invitations")
}

model PipelineStageTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  orderInPipeline Int
  color           String?  @default("#64748b")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderInPipeline])
  @@map("pipeline_stage_templates")
}

model CandidateTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  assignments CandidateTagAssignment[]

  @@map("candidate_tags")
}

model CandidateTagAssignment {
  candidateId String
  tagId       String

  candidate Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tag       CandidateTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([candidateId, tagId])
  @@map("candidate_tag_assignments")
}

model InterviewTemplate {
  id              String        @id @default(cuid())
  title           String
  subject         String?
  body            String        @db.Text
  durationMinutes Int           @default(45)
  type            InterviewType @default(ONLINE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([createdAt])
  @@map("interview_templates")
}

model LanguageLevelOption {
  id        String       @id @default(cuid())
  language  LanguageType
  label     String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())

  @@unique([language, label])
  @@index([language, sortOrder])
  @@map("language_level_options")
}

enum CandidateFieldType {
  STANDARD
  TEXT
  DROPDOWN
}

model RejectionReason {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  candidates Candidate[]

  @@index([sortOrder])
  @@map("rejection_reasons")
}

model CandidateFieldDefinition {
  id        String             @id @default(cuid())
  fieldKey  String             @unique
  label     String
  fieldType CandidateFieldType @default(STANDARD)
  visible   Boolean            @default(true)
  sortOrder Int                @default(0)
  options   String?            @db.Text
  isCustom  Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([sortOrder])
  @@map("candidate_field_definitions")
}

model CandidateCustomFieldValue {
  id          String   @id @default(cuid())
  candidateId String
  fieldKey    String
  value       String?
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, fieldKey])
  @@index([candidateId])
  @@map("candidate_custom_field_values")
}

model Job {
  id               String      @id @default(cuid())
  title            String
  description      String      @db.Text
  responsibilities String?     @db.Text
  requiredSkills   String?     @db.Text
  weOffer          String?     @db.Text
  location         String?
  employmentType   String?
  status           JobStatus   @default(DRAFT)
  headcount        Int         @default(1)
  recruiterId      String?
  openedAt         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  recruiter       User?                  @relation("JobRecruiter", fields: [recruiterId], references: [id], onDelete: SetNull)
  stages          Stage[]
  candidates      Candidate[]
  applications    CandidateApplication[]
  workforceEvents WorkforceEvent[]
  evaluationCriteria JobEvaluationCriterion[]

  @@index([status])
  @@index([recruiterId])
  @@map("jobs")
}

model Stage {
  id                String      @id @default(cuid())
  name              String
  orderInPipeline   Int
  automationEnabled Boolean     @default(false)
  jobId             String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  job          Job                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidates   Candidate[]
  applications CandidateApplication[]

  @@unique([jobId, orderInPipeline])
  @@index([jobId])
  @@map("stages")
}

model Candidate {
  id                String            @id @default(cuid())
  name              String
  email             String?
  phone             String?
  resumeLink        String?
  avatarUrl         String?
  position          String?
  coverLetter       String?           @db.Text
  englishLevel      String?
  chineseLevel      String?
  expectedSalary    Int?
  salaryCurrency    String?           @default("USD")
  applicationSource ApplicationSource @default(MANUAL)
  score             Int?
  skills            String[]          @default([])
  resumeText        String?           @db.Text
  evaluationAverage Float?
  emailsSent        Int               @default(0)
  emailsReceived    Int               @default(0)
  isNew             Boolean           @default(true)
  location          String?
  telegram          String?
  offerLink         String?
  firstContactDate  DateTime?
  lastContactDate   DateTime?
  stageId           String
  jobId             String
  recruiterId       String?
  rejectionReasonId String?
  rejectionNote     String?           @db.Text
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  stage           Stage                    @relation(fields: [stageId], references: [id], onDelete: Restrict)
  job             Job                      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  recruiter       User?                    @relation("CandidateRecruiter", fields: [recruiterId], references: [id], onDelete: SetNull)
  rejectionReason RejectionReason?         @relation(fields: [rejectionReasonId], references: [id], onDelete: SetNull)
  tagAssignments  CandidateTagAssignment[]
  applications    CandidateApplication[]
  workforceEvents WorkforceEvent[]
  candidateNotes  CandidateNote[]
  interviews      Interview[]
  emailMessages   EmailMessage[]
  testAssignments CandidateTestAssignment[]
  documents       CandidateDocument[]
  customFieldValues CandidateCustomFieldValue[]
  evaluationScores CandidateEvaluationScore[]
  links           CandidateLink[]

  @@index([stageId])
  @@index([jobId])
  @@index([email])
  @@index([recruiterId])
  @@index([rejectionReasonId])
  @@map("candidates")
}

model CandidateLink {
  id          String   @id @default(cuid())
  candidateId String
  label       String
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_links")
}

model CandidateApplication {
  id          String   @id @default(cuid())
  candidateId String
  jobId       String
  stageId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage     Stage     @relation(fields: [stageId], references: [id], onDelete: Restrict)

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId, stageId])
  @@map("candidate_applications")
}

model CandidateNote {
  id             String   @id @default(cuid())
  content        String   @db.Text
  candidateId    String
  authorId       String?
  authorName     String
  authorRole     String?
  authorPhotoUrl String?
  createdAt      DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@map("candidate_notes")
}

model Interview {
  id              String          @id @default(cuid())
  candidateId     String
  title           String
  status          InterviewStatus @default(PENDING)
  scheduledAt     DateTime
  type            InterviewType   @default(ONLINE)
  durationMinutes Int             @default(45)
  messageBody     String?         @db.Text
  meetLink        String?
  calendarEventId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  candidate     Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  emailMessages EmailMessage[]

  @@index([candidateId, scheduledAt])
  @@index([meetLink])
  @@map("interviews")
}

model EmailMessage {
  id             String             @id @default(cuid())
  candidateId    String
  interviewId    String?
  direction      EmailDirection     @default(OUTBOUND)
  status         EmailMessageStatus @default(QUEUED)
  senderName     String
  senderEmail    String
  recipientName  String
  recipientEmail String
  ccEmails       String?
  subject        String
  body           String             @db.Text
  isRead         Boolean            @default(false)
  isClicked      Boolean            @default(false)
  openedAt       DateTime?
  clickedAt      DateTime?
  sentAt         DateTime           @default(now())
  providerId     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  candidate Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interview Interview? @relation(fields: [interviewId], references: [id], onDelete: SetNull)

  @@index([candidateId, sentAt])
  @@index([interviewId])
  @@map("email_messages")
}

model WorkforceEvent {
  id          String             @id @default(cuid())
  type        WorkforceEventType
  personName  String
  jobTitle    String?
  note        String?
  occurredAt  DateTime           @default(now())
  candidateId String?
  jobId       String?
  createdAt   DateTime           @default(now())

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  job       Job?       @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([type, occurredAt])
  @@index([occurredAt])
  @@map("workforce_events")
}

model KnowledgeArticle {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  authorId   String?
  authorName String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@map("knowledge_articles")
}

model TestAssignmentTemplate {
  id             String   @id @default(cuid())
  title          String
  description    String?  @db.Text
  fileName       String
  filePath       String
  mimeType       String
  fileSize       Int
  uploadedById   String?
  uploadedByName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments CandidateTestAssignment[]

  @@index([createdAt])
  @@map("test_assignment_templates")
}

model CandidateTestAssignment {
  id              String                       @id @default(cuid())
  candidateId     String
  templateId      String
  sentById        String?
  sentByName      String
  status          TestAssignmentDeliveryStatus @default(QUEUED)
  gmailMessageId  String?
  uploadToken     String?                      @unique
  uploadExpiresAt DateTime?
  submittedAt     DateTime?
  submissionNote  String?                      @db.Text
  sentAt          DateTime?
  createdAt       DateTime                     @default(now())

  candidate Candidate              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  template  TestAssignmentTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([candidateId, createdAt])
  @@map("candidate_test_assignments")
}

model IntegrationState {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("integration_state")
}

model CandidateDocument {
  id             String                    @id @default(cuid())
  candidateId    String
  category       CandidateDocumentCategory @default(OTHER)
  title          String
  fileName       String
  filePath       String
  mimeType       String
  fileSize       Int
  uploadedById   String?
  uploadedByName String
  createdAt      DateTime                  @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("candidate_documents")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  title     String
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("email_templates")
}

model JobEvaluationCriterion {
  id        String   @id @default(cuid())
  jobId     String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  job    Job                      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scores CandidateEvaluationScore[]

  @@index([jobId, sortOrder])
  @@map("job_evaluation_criteria")
}

model CandidateEvaluationScore {
  id          String   @id @default(cuid())
  candidateId String
  criterionId String
  score       Int
  authorId    String?
  authorName  String
  updatedAt   DateTime @updatedAt

  candidate Candidate              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  criterion JobEvaluationCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@unique([candidateId, criterionId])
  @@index([candidateId])
  @@map("candidate_evaluation_scores")
}
